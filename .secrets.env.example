# Copy to .secrets.env and fill values before running scripts/run-poc.ps1
#
# Optional:
# WSL_DISTRO can force which distro is used for ansible runtime (default: Ubuntu).
WSL_DISTRO=Ubuntu
#
# Execution mode:
# - vsphere: Terraform provisions VM via vCenter (default)
# - local: reuse an existing local VMware VM and skip Terraform
POC_MODE=vsphere
LOCAL_BASTION_HOST=local-bastion.example.local

TF_VAR_vsphere_server=vcenter.example.local
TF_VAR_vsphere_user=administrator@vsphere.local
TF_VAR_vsphere_password=CHANGE_ME
TF_VAR_vsphere_allow_unverified_ssl=true

TF_VAR_datacenter=Datacenter
TF_VAR_cluster=Cluster
TF_VAR_datastore=Datastore
TF_VAR_network=VM Network
TF_VAR_resource_pool=Resources
TF_VAR_template_name=wallix-bastion-base-v1

TF_VAR_vm_name=wallix-bastion-poc
TF_VAR_vm_cpu=4
TF_VAR_vm_memory_mb=8192
TF_VAR_vm_disk_gb=120
TF_VAR_vm_folder=

# Optional static addressing (leave empty to rely on template/DHCP)
TF_VAR_enable_guest_customization=false
TF_VAR_bastion_ip=
TF_VAR_bastion_netmask=24
TF_VAR_bastion_gateway=
TF_VAR_dns_servers=[]
TF_VAR_bastion_domain=localdomain

# Ansible / WALLIX API
WALLIX_API_URL=
WALLIX_API_USER=admin
WALLIX_API_PASSWORD=CHANGE_ME
WALLIX_ADMIN_NEW_PASSWORD=CHANGE_ME_TOO
WALLIX_VALIDATE_CERTS=false

# Optional: apply WALLIX "assets" (devices/groups/authorizations) after configure
WALLIX_ASSETS_ENABLED=false
