# Copy to secrets_pnetlab.env (DO NOT COMMIT) then run: bash scripts/run-pnetlab.sh
#
# This file is meant to be sourced from bash:
#   set -a; source ./secrets_pnetlab.env; set +a
#
# Terraform reads TF_VAR_* automatically.

# ---- PNETLab / EVE-NG API (optional) ----
# SSH mode doesn't require the API, but we keep these vars for convenience.
# Tip: your PNETLab VM NAT IP can be fetched from VMware Workstation (vmrun getGuestIPAddress).
TF_VAR_pnet_api_url=https://192.168.214.128
TF_VAR_pnet_api_user=admin
# Default on fresh PNETLab installs: admin / pnet
TF_VAR_pnet_api_password=pnet

# ---- PNETLab SSH (required for ISO upload + qemu-img commit) ----
TF_VAR_pnet_ssh_host=192.168.214.128
TF_VAR_pnet_ssh_user=root
# Use ONE of the two below:
# Default on fresh PNETLab installs: root / pnet
TF_VAR_pnet_ssh_password=pnet
TF_VAR_pnet_ssh_key_path=
TF_VAR_pnet_tenant_id=1
TF_VAR_pnet_session_id=1

# ---- Labs ----
TF_VAR_pnet_lab_path=User1/Wallix-Auto.unl
TF_VAR_pnet_build_lab_path=User1/Wallix-TemplateBuild.unl

# ---- MGMT network ----
# pnet0 is usually the first physical NIC of PNETLab (often the one with internet/DHCP).
TF_VAR_pnet_mgmt_network_name=MGMT
TF_VAR_pnet_mgmt_network_type=pnet0

# Subnet where the WALLIX node will get its IP (DHCP)
TF_VAR_mgmt_subnet=192.168.214.0/24
TF_VAR_wallix_discovery_timeout_sec=1800

# ---- WALLIX image/template ----
# Path is relative to terraform/pnetlab/
# The ISO itself is not meant to be versioned in Git.
# Default below assumes the file is placed at the project root:
#   ./bastion-12.0.17.iso
TF_VAR_wallix_iso_path=../../bastion-12.0.17.iso
# Must match the QEMU image folder on PNETLab under /opt/unetlab/addons/qemu/
TF_VAR_wallix_image_name=linux-wallix-bastion-12.0.17
TF_VAR_wallix_disk_size=120G
TF_VAR_wallix_pod_id=0

# Node sizing (PoC defaults)
TF_VAR_wallix_cpu=4
TF_VAR_wallix_ram_mb=8192
TF_VAR_wallix_ethernet=1

# ---- WALLIX API (Ansible) ----
# Bootstrap password = "just installed" password; Desired password = what we want at the end.
WALLIX_API_USER=admin
WALLIX_API_PASSWORD=admin
WALLIX_ADMIN_NEW_PASSWORD=CHANGE_ME_TO_STRONG
WALLIX_VALIDATE_CERTS=false

# ---- Optional: WALLIX management SSH (break-glass recovery) ----
# When provided, Ansible can auto-restore the 'admin' web/API account if API auth fails
# (uses /opt/wab/bin/WABRestoreDefaultAdmin via SSH port 2242).
#
# In most appliances:
# - SSH user is wabadmin
# - SSH port is 2242
#
# If WALLIX_SSH_SUPER_PASSWORD is empty, the playbook will reuse WALLIX_SSH_PASSWORD.
WALLIX_SSH_HOST=
WALLIX_SSH_PORT=2242
WALLIX_SSH_USER=wabadmin
WALLIX_SSH_PASSWORD=
WALLIX_SSH_SUPER_PASSWORD=

# ---- Optional: create PoC users (one per WALLIX profile) ----
# When enabled, Ansible will ensure the users declared in ansible/group_vars/all.yml
# exist (default usernames: poc_approver, poc_auditor, ...).
#
# Password used for these users:
# - If WALLIX_MANAGED_USERS_PASSWORD is set, it is used.
# - Otherwise, the playbook reuses WALLIX_ADMIN_NEW_PASSWORD (PoC convenience).
WALLIX_MANAGED_USERS_ENABLED=false
WALLIX_MANAGED_USERS_PASSWORD=

# ---- Optional: apply WALLIX "assets" (devices, user groups, target groups, authorizations) ----
# This runs ansible/playbooks/assets.yml, which reads ansible/data/wallix_assets.yml by default.
# Enable with:
#   WALLIX_ASSETS_ENABLED=true
WALLIX_ASSETS_ENABLED=false

# Secrets referenced by ansible/data/wallix_assets.yml (example)
# Windows DC IP/hostname (used by the 'winserver_dc' device in assets).
# If empty, assets defaults to a PoC value and you may need to override it.
WIN_DC_HOST=
# Windows DC local Administrator password used to seed the credential in WALLIX.
WIN_DC_ADMIN_PASSWORD=
