# Copy to secrets_local.env and fill values before running the local mode
#
# Local mode reuses an existing WALLIX VM and skips Terraform.

POC_MODE=local

# Existing WALLIX Bastion reachable from the runner or from the local machine
LOCAL_BASTION_HOST=192.168.214.10

# Optional: if empty, scripts derive https://LOCAL_BASTION_HOST
WALLIX_API_URL=

# WALLIX API / web credentials
WALLIX_API_USER=admin
WALLIX_API_PASSWORD=CHANGE_ME
WALLIX_ADMIN_NEW_PASSWORD=CHANGE_ME_TOO
WALLIX_VALIDATE_CERTS=false

# Optional management SSH recovery
WALLIX_SSH_HOST=
WALLIX_SSH_PORT=2242
WALLIX_SSH_USER=wabadmin
WALLIX_SSH_PASSWORD=
WALLIX_SSH_SUPER_PASSWORD=

# Optional managed users
WALLIX_MANAGED_USERS_ENABLED=false
WALLIX_MANAGED_USERS_PASSWORD=

# Optional assets
WALLIX_ASSETS_ENABLED=false
WIN_DC_HOST=
WIN_DC_ADMIN_PASSWORD=
